        usdt = new MockERC20("Tether USD", "USDT", 6);
        vrfCoordinator = makeAddr("vrfCoordinator");
        jackpotClaimer = makeAddr("jackpotClaimer");

        vm.mockCall(
            jackpotClaimer,
            abi.encodeWithSelector(IJackpotClaimer.credit.selector),
