    function test_closeEpoch_whenEpochNotOpen_reverts() public {
        vm.startPrank(operator);
        vm.expectRevert(
            abi.encodeWithSelector(
                ISnaxpot.InvalidEpochState.selector,
                1,
                ISnaxpot.EpochState.NONE,
                ISnaxpot.EpochState.OPEN
            )
